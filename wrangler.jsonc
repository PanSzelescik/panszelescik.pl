{
    "main": ".open-next/worker.js",
    "name": "panszelescik",
    "compatibility_date": "2025-09-16",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
    },
    "workers_dev": false,
    "routes": [
        {
            "pattern": "panszelescik.pl",
            "custom_domain": true
        }
    ],
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1
    },
    "placement": {
        "mode": "smart"
    },
    "services": [
        {
            "binding": "WORKER_SELF_REFERENCE",
            "service": "panszelescik"
        }
    ],
    "r2_buckets": [
        {
            "binding": "NEXT_INC_CACHE_R2_BUCKET",
            "bucket_name": "panszelescik"
        }
    ],
    "durable_objects": {
        "bindings": [
            {
                "name": "NEXT_CACHE_DO_QUEUE",
                "class_name": "DOQueueHandler"
            }
        ]
    },
    "migrations": [
        {
            "tag": "v1",
            "new_sqlite_classes": [
                "DOQueueHandler"
            ]
        }
    ],
    "d1_databases": [
        {
            "binding": "NEXT_TAG_CACHE_D1",
            "database_id": "panszelescik",
            "database_name": "panszelescik"
        }
    ]
}